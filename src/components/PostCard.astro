---
interface Props {
  title: string
  description: string
  href: string
  tier: 'foundations' | 'applied' | 'professional'
  category: string
  publishDate: Date
  estimatedMinutes: number
  tags?: string[]
}

const { title, description, href, tier, category, publishDate, estimatedMinutes, tags = [] } = Astro.props

const tierLabel = { foundations: 'Foundations', applied: 'Applied', professional: 'Professional' }
const dateStr = publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
---

<a href={href} class="post-card block group">
  <div class="p-5">
    <div class="flex items-center gap-2 mb-3">
      <span class={`tier-badge tier-badge--${tier}`}>{tierLabel[tier]}</span>
      <span class="text-xs text-sky-muted capitalize">{category.replace('-', ' ')}</span>
      <span class="text-xs text-sky-muted ml-auto">{estimatedMinutes} min</span>
    </div>

    <h3 class="text-base font-semibold text-sky-text group-hover:text-brand-blue transition-colors mb-2 line-clamp-2">
      {title}
    </h3>

    <p class="text-sm text-sky-muted line-clamp-2 mb-3">
      {description}
    </p>

    <div class="flex items-center justify-between">
      <time datetime={publishDate.toISOString()} class="text-xs text-sky-muted">
        {dateStr}
      </time>
      {tags.length > 0 && (
        <div class="flex gap-1.5">
          {tags.slice(0, 3).map((tag) => (
            <span class="text-xs text-sky-muted bg-sky-bg px-2 py-0.5 rounded">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </div>
</a>
