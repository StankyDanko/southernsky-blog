---
interface Props {
  level: 'beginner' | 'intermediate' | 'advanced' | 'expert'
}

const { level } = Astro.props

const config = {
  beginner: { label: 'Beginner', class: 'bg-green-500/15 text-green-400' },
  intermediate: { label: 'Intermediate', class: 'bg-blue-500/15 text-blue-400' },
  advanced: { label: 'Advanced', class: 'bg-amber-500/15 text-amber-400' },
  expert: { label: 'Expert', class: 'bg-red-500/15 text-red-400' },
}

const { label, class: cls } = config[level]
---

<span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ${cls}`}>
  {label}
</span>
