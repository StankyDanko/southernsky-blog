---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
---

<BaseLayout title="404 — Page Not Found" description="This page doesn't exist on the SouthernSky Engineering Blog.">
  <Header slot="header" />

  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-24 text-center">
    <p class="text-6xl font-bold text-brand-blue mb-4">404</p>
    <h1 class="text-2xl font-bold text-sky-text mb-3">Page Not Found</h1>
    <p class="text-sky-muted mb-8">
      This page doesn't exist — but there's plenty to explore.
    </p>
    <div class="flex justify-center gap-4">
      <a href="/" class="px-4 py-2 bg-brand-blue text-white rounded-lg text-sm font-medium hover:bg-brand-blue/80 transition-colors">
        Homepage
      </a>
      <a href="/category/foundations" class="px-4 py-2 border border-sky-border text-sky-text rounded-lg text-sm font-medium hover:border-brand-blue transition-colors">
        Start Learning
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
