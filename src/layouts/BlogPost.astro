---
import BaseLayout from './BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import DifficultyBadge from '../components/DifficultyBadge.astro'
import AnimatedHero from '../components/AnimatedHero.astro'
import { articleJsonLd, breadcrumbJsonLd } from '../lib/structured-data'
import { siteConfig } from '../data/site-config'

const { frontmatter, headings } = Astro.props

const tierLabel = { foundations: 'Foundations', applied: 'Applied', professional: 'Professional' }
const dateStr = new Date(frontmatter.publishDate).toLocaleDateString('en-US', {
  month: 'long', day: 'numeric', year: 'numeric',
})

const jsonLd = [
  articleJsonLd(frontmatter),
  breadcrumbJsonLd([
    { name: 'Home', url: siteConfig.url },
    { name: tierLabel[frontmatter.tier as keyof typeof tierLabel], url: `${siteConfig.url}/category/${frontmatter.tier}` },
    { name: frontmatter.title, url: `${siteConfig.url}${Astro.url.pathname}` },
  ]),
]

const toc = headings?.filter((h: { depth: number }) => h.depth <= 3) || []
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  ogImage={frontmatter.heroImage ? `${siteConfig.url}${frontmatter.heroImage}` : undefined}
  jsonLd={jsonLd}
>
  <Header slot="header" />

  <article class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <nav class="text-xs text-sky-muted mb-6">
      <a href="/" class="hover:text-brand-blue transition-colors">Home</a>
      <span class="mx-1.5">/</span>
      <a href={`/category/${frontmatter.tier}`} class="hover:text-brand-blue transition-colors capitalize">
        {tierLabel[frontmatter.tier as keyof typeof tierLabel]}
      </a>
      <span class="mx-1.5">/</span>
      <span class="text-sky-text">{frontmatter.title}</span>
    </nav>

    {frontmatter.heroImage && (
      <div class="mb-8 -mx-4 sm:mx-0 sm:rounded-xl overflow-hidden">
        <AnimatedHero
          image={frontmatter.heroImage}
          alt={frontmatter.title}
          animated={true}
          class="h-48 sm:h-64 lg:h-80"
        />
      </div>
    )}

    <header class="mb-10">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <span class={`tier-badge tier-badge--${frontmatter.tier}`}>
          {tierLabel[frontmatter.tier as keyof typeof tierLabel]}
        </span>
        <DifficultyBadge level={frontmatter.difficulty} />
        <span class="text-xs text-sky-muted">{frontmatter.estimatedMinutes} min read</span>
      </div>

      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-sky-text mb-4 leading-tight">
        {frontmatter.title}
      </h1>

      <p class="text-sky-muted text-sm sm:text-base leading-relaxed mb-4">
        {frontmatter.description}
      </p>

      <div class="flex items-center gap-3 text-xs text-sky-muted">
        <span>By {frontmatter.author === 'j-martin' ? 'J. Martin' : frontmatter.author}</span>
        <span>&middot;</span>
        <time datetime={new Date(frontmatter.publishDate).toISOString()}>{dateStr}</time>
        <span>&middot;</span>
        <span class="capitalize">{frontmatter.category.replace(/-/g, ' ')}</span>
      </div>

      {frontmatter.tags?.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-4">
          {frontmatter.tags.map((tag: string) => (
            <a
              href={`/tag/${tag}`}
              class="text-xs text-sky-muted bg-sky-card px-2.5 py-1 rounded hover:text-brand-blue hover:bg-sky-border transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      )}

      {frontmatter.certTracks?.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-3">
          {frontmatter.certTracks.map((track: string) => (
            <a
              href={`/cert-track/${track}`}
              class="text-xs font-medium text-brand-blue bg-brand-blue/10 px-2.5 py-1 rounded hover:bg-brand-blue/20 transition-colors"
            >
              {track.replace(/-/g, ' ').replace(/comptia /i, 'CompTIA ')}
            </a>
          ))}
        </div>
      )}
    </header>

    {toc.length > 3 && (
      <details class="mb-8 bg-sky-card border border-sky-border rounded-xl p-4 lg:hidden">
        <summary class="text-xs font-semibold text-sky-muted uppercase tracking-wide cursor-pointer">
          Table of Contents
        </summary>
        <nav class="mt-3 space-y-1.5">
          {toc.map((heading: { depth: number; slug: string; text: string }) => (
            <a
              href={`#${heading.slug}`}
              class:list={[
                'block text-sm text-sky-muted hover:text-brand-blue transition-colors',
                heading.depth === 3 && 'pl-4',
              ]}
            >
              {heading.text}
            </a>
          ))}
        </nav>
      </details>
    )}

    <div class="lg:grid lg:grid-cols-[1fr_200px] lg:gap-10">
      <div class="prose prose-invert max-w-none">
        <slot />
      </div>

      {toc.length > 3 && (
        <aside class="hidden lg:block">
          <nav class="sticky top-20 space-y-1.5">
            <p class="text-xs font-semibold text-sky-muted uppercase tracking-wide mb-3">
              On this page
            </p>
            {toc.map((heading: { depth: number; slug: string; text: string }) => (
              <a
                href={`#${heading.slug}`}
                class:list={[
                  'block text-xs text-sky-muted hover:text-brand-blue transition-colors',
                  heading.depth === 3 && 'pl-3',
                ]}
              >
                {heading.text}
              </a>
            ))}
          </nav>
        </aside>
      )}
    </div>

    <footer class="mt-14 pt-8 border-t border-sky-border">
      <div class="flex items-center gap-4">
        <img
          src="/images/authors/j-martin.webp"
          alt="J. Martin"
          class="w-12 h-12 rounded-full object-cover"
          width="48"
          height="48"
        />
        <div>
          <p class="text-sm font-semibold text-sky-text">J. Martin</p>
          <p class="text-xs text-sky-muted">Software Engineer at SouthernSky Cloud LLC</p>
        </div>
      </div>
    </footer>
  </article>

  <Footer slot="footer" />
</BaseLayout>
